# Copy this file to scripts/deploy.env and edit values for your board.
# Do not commit scripts/deploy.env.

BOARD_HOST=your-board-ip
BOARD_USER=root
BOARD_DIR=/path/on/board

# Override these only if needed.
ARM_CC=arm-linux-gnueabihf-gcc
LOCAL_BINARY=build/lumina_frame_arm
REMOTE_BINARY=lumina_frame
SSH_CONNECT_TIMEOUT=8
DEPLOY_RETRIES=3
DEPLOY_RETRY_DELAY=2
SSH_STRICT_HOST_KEY_CHECKING=accept-new
